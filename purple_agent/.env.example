# ═══════════════════════════════════════════════════════════════════
# Purple Agent -- Environment Variables v7.0
# Copy to .env and fill in real values before running.
# All values have sensible defaults in config.py.
# ═══════════════════════════════════════════════════════════════════

# Required
OPENAI_API_KEY=sk-your-key-here

# Agent Connectivity
GREEN_AGENT_URL=http://localhost:9090
A2A_SERVER_HOST=0.0.0.0
A2A_SERVER_PORT=8080

# Detection Tuning (override defaults from config.py)
# STRUCTURING_MIN_USD=9000
# STRUCTURING_MAX_USD=9800
# CTR_THRESHOLD_USD=10000
# STRUCTURING_MIN_COUNT=10
# STRUCTURING_MIN_COUNT_INR=10
# CONFIDENCE_THRESHOLD=0.5

# Graph Safety
# MAX_NODE_DEGREE=500
# MAX_PATHS_PER_SEARCH=1000
# MAX_DFS_DEPTH=15

# SAR Generation
# SAR_LLM_MODEL=gpt-4o-mini
# SAR_LLM_TEMPERATURE=0.0
# SAR_LLM_SEED=42
# SAR_MAX_RETRY=3
# SAR_MAX_NARRATIVE_CHARS=10000

# NLP
# SPACY_MODEL=en_core_web_sm

# Operations
LOG_LEVEL=INFO
# RALPH_TIMEOUT=120

# Determinism (set in Dockerfile; override here for local dev)
PYTHONHASHSEED=0
